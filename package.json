{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "obsidian-smart-capture",
  "title": "Obsidian Smart Capture",
  "description": "Smart capture anything into Obsidian",
  "icon": "command-icon.png",
  "author": "millin_gabani",
  "categories": [
    "Productivity"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "capture",
      "title": "Obsidian Smart Capture",
      "description": "Capture whats on your screen into obsidian",
      "mode": "view",
      "preferences": [
        {
          "name": "aiTitleAutofill",
          "title": "AI Title Autofill",
          "description": "Use AI to generate a contextual title based on the captured content and source app (requires Raycast Pro)",
          "type": "checkbox",
          "default": true,
          "label": "Enable AI title suggestions",
          "required": false
        }
      ]
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.8",
    "@raycast/utils": "^1.9.1",
    "yaml": "^2.3.1"
  },
  "devDependencies": {
    "@raycast/eslint-config": "1.0.5",
    "@types/node": "18.8.3",
    "@types/react": "^19.0.10",
    "eslint": "^7.32.0",
    "prettier": "^2.5.1",
    "typescript": "^4.4.3",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish",
    "test": "vitest run",
    "test:watch": "vitest"
  }
}
